"VertexlitGeneric"
{
	"$basetexture" "vgui\replay\thumbnails\models/weapons/c_models/c_minigun/t_minigun_02_stock"
	
		 "$phong" "1"
		 "$phongexponent" "8"
		 "$phongboost" "1"	
	     "$lightwarptexture" "models\lightwarps\weapon_lightwarp"
         "$phongfresnelranges"	"[.5 .5 .5]"

	"$phongExponentTexture" "vgui\replay\thumbnails\models/weapons/c_models/c_minigun/specular_03"
	$phongAlbedoTint 1
	
//SheenColor
     $phongwarptexture "vgui\replay\thumbnails\models/weapons/c_models/c_minigun/sheen_13"


	"$rimlight" "1"						
	"$rimlightexponent" "1"				
	"$rimlightboost" "24"

//Cubemap stuff
	"$envmap" "env_cubemap"	
	"$envmaptint" "[0.01 0.01 0.01 ]"

//Jaraterfix?: //sheenfix:
	"$halflambert" "1"

"$glowcolor" "1"


"$tempvar" "0"

	// Cloaking
	"$cloakPassEnabled" "1"
	"$sheenPassEnabled" "1"

	"$sheenmap" 		"cubemaps/cubemap_sheen001"
	"$sheenmapmask" 		"Effects/AnimatedSheen/animatedsheen0"
	"$sheenmaptint" 		"[ 1 1 1 ]"
	"$sheenmapmaskframe" 	"0"
	"$sheenindex" 		"0"

	"$yellow" "0"

	"Proxies"
	{
		"AnimatedWeaponSheen"
		{
			"animatedtexturevar" 		"$sheenmapmask"
			"animatedtextureframenumvar" 	"$sheenmapmaskframe"
			"animatedtextureframerate" 		"40"
		}
		"invis"
		{
		}
		"ModelGlowColor"
		{
			"resultVar" "$glowcolor"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$selfillumtint"
		}
		"Equals"
		{
			"srcVar1"  "$glowcolor"
			"resultVar" "$color2"
		}
		"YellowLevel"
		{
			"resultVar" "$yellow"
		}
		"Multiply"
		{
			"srcVar1" "$color2"
			"srcVar2" "$yellow"
			"resultVar" "$color2"
		}
	
	
		"WeaponSkin" {
		}
	}
}
